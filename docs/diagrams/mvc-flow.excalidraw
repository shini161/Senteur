    },
    {
      "id": "HmO3pFUntPskKsb228sJm",
      "type": "text",
      "x": 1168.0916748046875,
      "y": 443,
      "width": 799.816650390625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 49080897,
      "version": 92,
      "versionNonce": 1295589121,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1777218698265,
      "link": null,
      "locked": false,
      "text": "Service → The \"Brain.\" It executes business logic (e.g., \"Can this user buy this?\").\nIt talks to the Repository.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Service → The \"Brain.\" It executes business logic (e.g., \"Can this user buy this?\"). It talks to the Repository.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "DUWtTA5caz4YtLqofH07z",
      "type": "text",
      "x": 1176.2749938964844,
      "y": 552.5,
      "width": 793.4500122070312,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 509515343,
      "version": 88,
      "versionNonce": 1333662369,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1777218698911,
      "link": null,
      "locked": false,
      "text": "Repository → The \"Librarian.\" It runs the SQL/PDO and returns a Model/Entity.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Repository → The \"Librarian.\" It runs the SQL/PDO and returns a Model/Entity.",
      "autoResize": true,
      "lineHeight": 1.25
    },
