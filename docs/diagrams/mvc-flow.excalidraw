      "isDeleted": true,
      "boundElements": null,
      "updated": 1777218696502,
      "link": null,
      "locked": false,
      "text": "Controller → Validates the request basics and calls the Service.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Controller → Validates the request basics and calls the Service.",
      "autoResize": true,
