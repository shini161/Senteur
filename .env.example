APP_ENV=local
APP_DEBUG=true

; Optional Docker Compose profile.
; Set to "cloudflare" to start a free temporary Quick Tunnel alongside the stack.
; Leave blank for regular localhost-only development.
COMPOSE_PROFILES=

; Internal origin used by the Cloudflare tunnel sidecar when the cloudflare
; profile is enabled. The default Nginx service target is usually correct.
CLOUDFLARE_TUNNEL_ORIGIN=http://nginx:80

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=senteur
DB_USERNAME=root
DB_PASSWORD=root

APP_URL=http://localhost:8080
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
